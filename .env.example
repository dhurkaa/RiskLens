# RiskLens environment configuration
#
# These are OPTIONAL. RiskLens ships with a fully offline demo workspace, so the
# app runs end-to-end without any of these values — just press
# "Use demo workspace" on the login screen.
#
# To connect a real Supabase backend, copy this file to `.env` and fill in:
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: an OpenAI (ChatGPT) API key turns the RiskLens Copilot into a full
# GPT chatbot. Your live inventory is passed to GPT as grounded context, so it
# answers about your real products without inventing numbers. Without a key, the
# Copilot still works using the built-in offline reasoning engine.
#
# NOTE: keys prefixed EXPO_PUBLIC_ are bundled into the app and visible to anyone
# who inspects it. Fine for a demo (revoke the key afterwards); for production,
# route requests through a small backend proxy instead.
EXPO_PUBLIC_OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini). e.g. gpt-4o
EXPO_PUBLIC_OPENAI_MODEL=

# Optional alternative LLM provider (Groq) — used only if no OpenAI key is set
# and you wire it in. Safe to leave blank.
EXPO_PUBLIC_GROQ_API_KEY=
